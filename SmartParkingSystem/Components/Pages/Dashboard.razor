@page "/dashboard"
@inherits DashboardBase

<section class="min-h-screen px-4 py-6 sm:px-6 lg:px-8">
    <div class="mx-auto w-full max-w-6xl">
        <header class="mb-8 flex flex-col gap-4 rounded-md bg-brand-100/80 px-4 py-4 sm:flex-row sm:items-end">
            <div>
                <p class="text-sm font-semibold text-calm-500">Smart Parking System</p>
                <p class="text-sm text-calm-700">Connected operator workspace</p>
            </div>

            <nav class="grid gap-2" aria-label="Primary">
                @foreach (var item in NavigationItems)
                {
                    <a href="@item.Href"
                       title="@item.Description"
                       class="inline-flex min-h-12 items-center gap-2 rounded-md bg-white/85 px-4 py-2 text-sm font-semibold text-calm-700 transition-all duration-500 ease-out hover:bg-brand-200"
                       aria-label="@item.Label">
                        <i data-lucide="@item.Icon"></i>
                        <span>@item.Label</span>
                    </a>
                }
            </nav>
        </header>

        <div class="grid gap-6">
            <div class="grid gap-4 rounded-md bg-brand-100/80 p-6 sm:p-8">
                <div class="inline-flex items-center gap-2 rounded-md bg-mint-100 px-4 py-2 text-sm font-semibold text-mint-700">
                    Connected and ready
                </div>

                <div class="grid gap-4">
                    <h1 class="text-5xl font-extrabold leading-none text-sky-500 sm:text-6xl">Dashboard preview after
                        startup</h1>
                    <p class="max-w-md text-base leading-7 text-calm-700 sm:text-lg">
                        This is the fake destination page after a successful device check. It already reflects the
                        calmer
                        visual direction from the docs and gives us a base for the real business screens.
                    </p>
                </div>
            </div>

            <section class="grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
                <div class="grid gap-4">
                    <article class="rounded-md bg-brand-100/70 p-5">
                        <p class="text-sm font-semibold text-calm-500">Free spots</p>
                        <p class="text-5xl font-extrabold text-calm-900">2</p>
                    </article>

                    <article class="rounded-md bg-mint-100 p-5">
                        <p class="text-sm font-semibold text-calm-500">Occupied spots</p>
                        <p class="text-5xl font-extrabold text-calm-900">1</p>
                    </article>
                </div>

                <div class="grid gap-4">
                    <article class="rounded-md bg-brand-100/70 p-5">
                        <p class="text-sm font-semibold text-calm-500">Gate state</p>
                        <p class="text-5xl font-extrabold text-calm-900">Open</p>
                    </article>

                    <article class="rounded-md bg-warm-100 p-5">
                        <p class="text-sm font-semibold text-calm-500">Last update</p>
                        <p class="text-5xl font-extrabold text-calm-900">10s</p>
                    </article>
                </div>
            </section>

            <section class="grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
                <article class="rounded-md bg-brand-100/80 p-6">
                    <div class="mb-2 flex items-center gap-3">
                        <div class="flex h-10 w-10 items-center justify-center rounded-md bg-calm-100 text-calm-700">
                            <i data-lucide="zap"></i>
                        </div>
                        <div>
                            <h2 class="text-base font-semibold text-calm-900">Quick actions</h2>
                            <p class="text-sm text-calm-700">Temporary fake control surface</p>
                        </div>
                    </div>

                    <div class="grid gap-3">
                        <button class="min-h-12 rounded-md bg-brand-300 px-4 py-3 text-sm font-semibold text-calm-900 transition-all duration-500 ease-out hover:bg-brand-400">
                            Open Gate
                        </button>
                        <button class="min-h-12 rounded-md bg-mint-300 px-4 py-3 text-sm font-semibold text-calm-900 transition-all duration-500 ease-out hover:bg-mint-200">
                            Refresh Data
                        </button>
                        <button class="min-h-12 rounded-md bg-warm-300 px-4 py-3 text-sm font-semibold text-warm-700 transition-all duration-500 ease-out hover:bg-warm-200">
                            Admin Mode
                        </button>
                    </div>
                </article>

                <article class="rounded-md bg-white/85 p-6">
                    <div class="mb-2 flex items-center gap-3">
                        <div class="flex h-10 w-10 items-center justify-center rounded-md bg-mint-100 text-mint-700">
                            <i data-lucide="clipboard-list"></i>
                        </div>
                        <div>
                            <h2 class="text-base font-semibold text-calm-900">Recent state</h2>
                            <p class="text-sm text-calm-700">Last fake system updates</p>
                        </div>
                    </div>

                    <ul class="grid gap-3 text-sm leading-6 text-calm-700">
                        <li class="rounded-md bg-brand-100/60 px-4 py-3">Bluetooth session active</li>
                        <li class="rounded-md bg-brand-100/60 px-4 py-3">HC-05 main controller selected</li>
                        <li class="rounded-md bg-brand-100/60 px-4 py-3">Parking place P2 is occupied</li>
                        <li class="rounded-md bg-brand-100/60 px-4 py-3">No warning conditions right now</li>
                    </ul>
                </article>
            </section>
        </div>
    </div>
</section>
