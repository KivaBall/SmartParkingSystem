@namespace SmartParkingSystem.Components.Pages.Workspace.Parts
@using SmartParkingSystem.Components.Pages.Connection.Parts
@inherits WorkspaceSettingsViewBase

<section class="grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="grid gap-4">
        <article class="@CurrentDeviceClass" style="@CurrentDeviceStyle">
            <div class="mb-8 flex items-center justify-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-md bg-white/85 text-calm-700">
                    <i data-lucide="monitor-smartphone"></i>
                </div>

                <div>
                    <p class="text-base font-semibold text-calm-900">@Texts.CurrentDeviceTitle</p>
                </div>
            </div>

            <div class="grid gap-3">
                @foreach (var item in DeviceItems)
                {
                    <div class="rounded-md bg-white/85 px-4 py-4">
                        <p class="text-sm font-semibold text-calm-500">@item.Label</p>
                        <p class="text-base font-semibold text-calm-900">@item.Value</p>
                    </div>
                }
            </div>
        </article>

        <article class="@InterfaceLanguageClass" style="@InterfaceLanguageStyle">
            <div class="mb-8 flex items-center justify-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-md bg-brand-100/80 text-calm-700">
                    <i data-lucide="languages"></i>
                </div>

                <div>
                    <p class="text-base font-semibold text-calm-900">@Texts.InterfaceLanguageTitle</p>
                </div>
            </div>

            <ConnectionLanguageSwitch EnglishButtonClass="@GetLanguageButtonClass(AppLanguage.English)"
                                      UkrainianButtonClass="@GetLanguageButtonClass(AppLanguage.Ukrainian)"
                                      OnLanguageSelected="SetLanguageAsync"/>
        </article>
    </div>

    <div class="grid gap-4">
        <article class="@EnvironmentClass" style="@EnvironmentStyle">
            <div class="mb-8 flex items-center justify-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-md bg-white/85 text-mint-700">
                    <i data-lucide="badge-info"></i>
                </div>

                <div>
                    <p class="text-base font-semibold text-calm-900">@Texts.EnvironmentTitle</p>
                </div>
            </div>

            <div class="grid gap-3">
                @foreach (var item in EnvironmentItems)
                {
                    <div class="rounded-md bg-white/85 px-4 py-4">
                        <p class="text-sm font-semibold text-calm-500">@item.Label</p>
                        <p class="text-base font-semibold text-calm-900">@item.Value</p>
                    </div>
                }
            </div>
        </article>

        <article class="@SessionClass" style="@SessionStyle">
            <div class="mb-8 flex items-center justify-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-md bg-white/85 text-warm-700">
                    <i data-lucide="log-out"></i>
                </div>

                <div>
                    <p class="text-base font-semibold text-calm-900">@Texts.SessionTitle</p>
                </div>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
                <button class="inline-flex min-h-12 items-center gap-2 rounded-md bg-warm-300 px-4 py-3 text-sm font-semibold text-warm-700 transition-all duration-500 ease-out hover:bg-warm-200"
                        @onclick='() => OnExitRequested.InvokeAsync()'>
                    <i data-lucide="arrow-left-right"></i>
                    <span>@Texts.BackToConnectionButton</span>
                </button>

                <button class="inline-flex min-h-12 items-center gap-2 rounded-md bg-brand-300 px-4 py-3 text-sm font-semibold text-calm-900 transition-all duration-500 ease-out hover:bg-brand-400"
                        @onclick='() => OnCloseRequested.InvokeAsync()'>
                    <i data-lucide="power"></i>
                    <span>@Texts.CloseApplicationButton</span>
                </button>
            </div>
        </article>
    </div>
</section>
