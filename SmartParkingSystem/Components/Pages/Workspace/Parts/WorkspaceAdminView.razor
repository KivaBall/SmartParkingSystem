@namespace SmartParkingSystem.Components.Pages.Workspace.Parts
@inherits WorkspaceAdminViewBase

<div class="space-y-4">
    @if (IsLoading)
    {
        <section class="rounded-md bg-white/85 p-6">
            <p class="text-base font-semibold text-calm-900">@Texts.RefreshButton</p>
            <p class="mt-2 text-sm font-semibold text-calm-500">@Texts.RefreshingMessage</p>
        </section>
    }
    else
    {
        <section class="@ActionsClass" style="@ActionsStyle">
            <div class="grid gap-3 lg:grid-cols-[1fr_auto] lg:items-center">
                <div class="flex min-h-12 items-center justify-center rounded-md bg-white/70 px-4 py-3 lg:justify-start">
                    <p class="text-sm font-semibold text-calm-700">
                        @StatusMessage
                    </p>
                </div>

                <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center lg:justify-end">
                    <button class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md bg-mint-300 px-4 py-3 text-sm font-semibold text-calm-900 transition-all duration-500 ease-out hover:bg-mint-200 disabled:cursor-default disabled:opacity-50"
                            disabled="@IsBusy"
                            @onclick="RefreshAsync">
                        <i data-lucide="refresh-cw"></i>
                        <span>@Texts.RefreshButton</span>
                    </button>

                    <button class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md bg-brand-300 px-4 py-3 text-sm font-semibold text-calm-900 transition-all duration-500 ease-out hover:bg-brand-400 disabled:cursor-default disabled:opacity-50"
                            disabled="@(!HasChanges || IsBusy)"
                            @onclick="SaveAsync">
                        <i data-lucide="save"></i>
                        <span>@Texts.SaveButton</span>
                    </button>

                    <button class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md bg-warm-300 px-4 py-3 text-sm font-semibold text-warm-700 transition-all duration-500 ease-out hover:bg-warm-200 disabled:cursor-default disabled:opacity-50"
                            disabled="@IsBusy"
                            @onclick="ResetAsync">
                        <i data-lucide="rotate-ccw"></i>
                        <span>@Texts.ResetButton</span>
                    </button>
                </div>
            </div>
        </section>

        <section class="@EditableClass" style="@EditableStyle">
            <div class="space-y-4">
                <div class="grid gap-4 lg:grid-cols-[1fr_1fr]">
                    <section class="@GateSectionClass" style="@GateSectionStyle">
                        <div class="mb-8 flex items-center justify-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-md bg-white/85 text-calm-700">
                                <i data-lucide="rows-4"></i>
                            </div>

                            <div>
                                <p class="text-base font-semibold text-calm-900">@Texts.GateTitle</p>
                            </div>
                        </div>

                        <div class="space-y-3">
                            <div class="rounded-md bg-white px-4 py-4">
                                <p class="mb-2 text-sm font-semibold text-calm-500">@Texts.ServoOpenAngleLabel</p>
                                <input class="min-h-12 w-full rounded-md bg-calm-50 px-4 py-3 text-base font-semibold text-calm-900 outline-none"
                                       type="number"
                                       min="0"
                                       max="180"
                                       @bind="EditableSettings.ServoOpenAngle"/>
                            </div>

                            <div class="rounded-md bg-white px-4 py-4">
                                <p class="mb-2 text-sm font-semibold text-calm-500">@Texts.ServoClosedAngleLabel</p>
                                <input class="min-h-12 w-full rounded-md bg-calm-50 px-4 py-3 text-base font-semibold text-calm-900 outline-none"
                                       type="number"
                                       min="0"
                                       max="180"
                                       @bind="EditableSettings.ServoClosedAngle"/>
                            </div>

                            <div class="rounded-md bg-white px-4 py-4">
                                <p class="mb-2 text-sm font-semibold text-calm-500">@Texts.ServoOpenDurationLabel</p>
                                <input class="min-h-12 w-full rounded-md bg-calm-50 px-4 py-3 text-base font-semibold text-calm-900 outline-none"
                                       type="number"
                                       min="250"
                                       @bind="EditableSettings.ServoOpenDurationMs"/>
                            </div>

                            <div class="rounded-md bg-white px-4 py-4">
                                <div class="flex items-center justify-between gap-3 rounded-md bg-calm-50 px-4 py-4">
                                    <div>
                                        <p class="text-sm font-semibold text-calm-900">@Texts.ForceGateOpenLabel</p>
                                    </div>

                                    <button class="@GetToggleButtonClass(EditableSettings.ForceGateOpen)"
                                            type="button"
                                            @onclick="ToggleForceGateOpen">
                                        <span>@GetToggleButtonLabel(EditableSettings.ForceGateOpen)</span>
                                    </button>
                                </div>
                            </div>

                            <div class="rounded-md bg-white px-4 py-4">
                                <div class="flex items-center justify-between gap-3 rounded-md bg-calm-50 px-4 py-4">
                                    <div>
                                        <p class="text-sm font-semibold text-calm-900">@Texts.ForceGateLockLabel</p>
                                    </div>

                                    <button class="@GetToggleButtonClass(EditableSettings.ForceGateLock)"
                                            type="button"
                                            @onclick="ToggleForceGateLock">
                                        <span>@GetToggleButtonLabel(EditableSettings.ForceGateLock)</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="@ParkingSectionClass" style="@ParkingSectionStyle">
                        <div class="mb-8 flex items-center justify-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-md bg-white/85 text-calm-700">
                                <i data-lucide="square-parking"></i>
                            </div>

                            <div>
                                <p class="text-base font-semibold text-calm-900">@Texts.ParkingTitle</p>
                            </div>
                        </div>

                        <div class="space-y-3">
                            <div class="rounded-md bg-white px-4 py-4">
                                <p class="mb-2 text-sm font-semibold text-calm-500">@Texts.OccupiedThresholdLabel</p>
                                <input class="min-h-12 w-full rounded-md bg-calm-50 px-4 py-3 text-base font-semibold text-calm-900 outline-none"
                                       type="number"
                                       min="1"
                                       @bind="EditableSettings.OccupiedThresholdCm"/>
                            </div>

                            <div class="rounded-md bg-white px-4 py-4">
                                <p class="mb-3 text-sm font-semibold text-calm-500">@Texts.DisabledParkingSlotsLabel</p>

                                <div class="grid gap-3 sm:grid-cols-[1fr_1fr]">
                                    @for (var slotIndex = 0; slotIndex < EditableSettings.ParkingSpotEnabledStates.Count; slotIndex++)
                                    {
                                        var currentSlotIndex = slotIndex;
                                        var enabled = EditableSettings.ParkingSpotEnabledStates[currentSlotIndex];

                                        <button class="@GetParkingToggleClass(!enabled)"
                                                type="button"
                                                @onclick="() => ToggleParkingSpot(currentSlotIndex)">
                                            <span>@GetParkingSpotLabel(currentSlotIndex + 1)</span>
                                            <span class="text-sm font-semibold">@GetToggleButtonLabel(enabled)</span>
                                        </button>
                                    }
                                </div>
                            </div>

                            <div class="rounded-md bg-white px-4 py-4">
                                <div class="flex items-center justify-between gap-3 rounded-md bg-calm-50 px-4 py-4">
                                    <div>
                                        <p class="text-sm font-semibold text-calm-900">@SettingsTexts.EditParkingLabel</p>
                                    </div>

                                    <button class="inline-flex min-h-12 items-center justify-center rounded-md px-4 py-3 text-sm font-semibold transition-all duration-500 ease-out @(EditParkingEnabled ? "bg-brand-200 text-calm-900 hover:bg-brand-400" : "bg-white text-calm-700 hover:bg-calm-50")"
                                            type="button"
                                            @onclick="ToggleEditParking">
                                        <span>@(EditParkingEnabled ? SettingsTexts.EnabledLabel : SettingsTexts.DisabledLabel)</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="grid gap-4 lg:grid-cols-[1fr_1fr]">
                    <section class="@CardsSectionClass" style="@CardsSectionStyle">
                        <div class="mb-8 flex items-center justify-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-md bg-brand-100/80 text-calm-700">
                                <i data-lucide="credit-card"></i>
                            </div>

                            <div>
                                <p class="text-base font-semibold text-calm-900">@Texts.CardsTitle</p>
                            </div>
                        </div>

                        <div class="grid gap-3 lg:grid-cols-[1fr_1fr]">
                            <div class="rounded-md bg-white px-4 py-4">
                                <p class="mb-2 text-sm font-semibold text-calm-500">@Texts.AllowedCardsLabel</p>
                                <textarea class="min-h-16 h-full w-full resize-none rounded-md bg-calm-50 px-4 py-3 text-base font-semibold text-calm-900 outline-none"
                                          @bind="EditableSettings.AllowedCardsText"></textarea>
                            </div>

                            <div class="rounded-md bg-white px-4 py-4">
                                <p class="mb-2 text-sm font-semibold text-calm-500">@Texts.BlockedCardsLabel</p>
                                <textarea class="min-h-16 h-full w-full resize-none rounded-md bg-calm-50 px-4 py-3 text-base font-semibold text-calm-900 outline-none"
                                          @bind="EditableSettings.BlockedCardsText"></textarea>
                            </div>
                        </div>
                    </section>

                    <section class="@SystemSectionClass" style="@SystemSectionStyle">
                        <div class="mb-8 flex items-center justify-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-md bg-white/85 text-warm-700">
                                <i data-lucide="cpu"></i>
                            </div>

                            <div>
                                <p class="text-base font-semibold text-calm-900">@Texts.SystemTitle</p>
                            </div>
                        </div>

                        <div class="rounded-md bg-white px-4 py-4">
                            <p class="mb-2 text-sm font-semibold text-calm-500">@Texts.TelemetryIntervalLabel</p>
                            <input class="min-h-12 w-full rounded-md bg-calm-50 px-4 py-3 text-base font-semibold text-calm-900 outline-none"
                                   type="number"
                                   min="250"
                                   @bind="EditableSettings.ParkingStatusUpdateIntervalMs"/>
                        </div>
                    </section>
                </div>
            </div>
        </section>
    }
</div>
