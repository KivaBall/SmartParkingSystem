@namespace SmartParkingSystem.Maui.Components.Pages.Connection.Parts
@inherits AdvancedConnectionPanelBase

<div class="@ContentClass">
    <div class="flex min-h-[12.5rem] flex-col justify-between gap-4">
        <div class="grid gap-4 sm:grid-cols-[1fr_auto_auto] sm:items-end">
            <div>
                <label class="mb-2 text-sm font-semibold text-calm-700" for="device-select">@DeviceLabel</label>
                <select id="device-select"
                        class="min-h-12 w-full appearance-none rounded-md bg-brand-100/60 px-4 py-3 text-calm-900 outline-none"
                        value="@SelectedTargetId"
                        @onchange='args => SelectedTargetIdChanged.InvokeAsync(args.Value?.ToString())'
                        disabled="@IsBusy">
                    @foreach (var target in Targets)
                    {
                        <option value="@target.Id">@target.Label</option>
                    }
                </select>
            </div>

            <button class="@WarningButtonClass" @onclick="OnRefresh" disabled="@IsBusy">
                @RefreshButtonText
            </button>

            <button class="@SecondaryButtonClass" @onclick="OnConnect" disabled="@IsBusy">
                @ConnectButtonText
            </button>
        </div>

        <div class="rounded-md bg-white/85 px-4 py-4 text-sm leading-6 text-calm-700">
            @Description
        </div>
    </div>
</div>
