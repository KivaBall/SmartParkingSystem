@namespace SmartParkingSystem.Maui.Components.Pages.Workspace.Parts
@inherits WorkspaceParkingViewBase

<style>
    .workspace-parking-floor-layer {
        transition: opacity 250ms ease-out;
    }

    .workspace-parking-edit-button {
        flex: 1 1 0;
        min-width: 0;
    }

    @@media (min-width: 640px) {
        .workspace-parking-edit-button {
            flex: 0 0 3.5rem;
            width: 3.5rem;
        }

        .workspace-parking-header-floor {
            position: absolute;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
        }

        .workspace-parking-header-fullscreen {
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
        }
    }

    .workspace-parking-fullscreen-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        overflow-y: auto;
        padding: 1rem;
        min-height: 100vh;
        background: linear-gradient(to bottom, #f5fbff, #eef9f6);
    }

    .workspace-parking-fullscreen-aspect {
        position: relative;
        aspect-ratio: 600 / 505;
        width: 100%;
        margin: 0 auto;
    }

    .workspace-parking-fullscreen-snapshot-img {
        display: block;
        width: 100%;
        max-height: 14rem;
        object-fit: cover;
        border-radius: 0.375rem;
    }

    @@media (min-width: 1024px) {
        .workspace-parking-fullscreen-overlay {
            overflow: hidden;
            height: 100vh;
            min-height: 0;
        }

        .workspace-parking-fullscreen-section {
            height: 100%;
            min-height: 0;
        }

        .workspace-parking-fullscreen-left {
            min-height: 0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .workspace-parking-fullscreen-article {
            flex: 1 1 0;
            min-height: 0;
            display: flex;
            flex-direction: column;
        }

        .workspace-parking-fullscreen-floor {
            flex: 1 1 0;
            min-height: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .workspace-parking-fullscreen-aspect {
            max-width: calc((100vh - 11rem) * 600 / 505);
        }

        .workspace-parking-fullscreen-aside {
            min-height: 0;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .workspace-parking-fullscreen-detail {
            flex: 1 1 0;
            min-height: 0;
            display: flex;
            flex-direction: column;
        }

        .workspace-parking-fullscreen-detail-grid {
            flex: 1 1 0;
            min-height: 0;
        }

        .workspace-parking-fullscreen-snapshot {
            flex: 1 1 0;
            min-height: 0;
            display: flex;
            flex-direction: column;
        }

        .workspace-parking-fullscreen-snapshot-img {
            flex: 1 1 0;
            min-height: 0;
            max-height: none;
            height: 100%;
            width: 100%;
            object-fit: cover;
        }
    }
</style>

@if (IsLoading)
{
    <section class="rounded-md bg-white/85 p-6">
        <p class="text-base font-semibold text-calm-900">@Texts.MapTitle</p>
        <p class="mt-2 text-sm font-semibold text-calm-500">@Texts.OccupiedDurationLabel...</p>
    </section>
}
else
{
    <div class="@(IsFullscreen ? "workspace-parking-fullscreen-overlay" : "")">
        <section class="@(IsFullscreen ? "workspace-parking-fullscreen-section grid gap-4 lg:grid-cols-[3fr_1fr]" : "space-y-4")">
            <div class="@(IsFullscreen ? "workspace-parking-fullscreen-left" : "space-y-4")">
                <article class="@MapClass @(IsFullscreen ? "workspace-parking-fullscreen-article" : "")" style="@MapStyle">
                    <div class="mb-8 flex flex-col items-center justify-center gap-3 sm:flex-row" style="position: relative;">
                        <button class="workspace-parking-header-fullscreen inline-flex h-12 w-12 items-center justify-center rounded-md bg-white/85 text-calm-700 transition-all duration-500 ease-out hover:bg-calm-100"
                                type="button"
                                aria-label="@(IsFullscreen ? Texts.ExitFullscreenButtonLabel : Texts.FullscreenButtonLabel)"
                                title="@(IsFullscreen ? Texts.ExitFullscreenButtonLabel : Texts.FullscreenButtonLabel)"
                                @onclick="ToggleFullscreen">
                            <span @key="@(IsFullscreen ? "fs-min" : "fs-max")" style="display: contents;">
                                <i data-lucide="@(IsFullscreen ? "minimize-2" : "maximize-2")"></i>
                            </span>
                        </button>

                        <div class="flex items-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-md bg-white/85 text-calm-700">
                                <i data-lucide="circle-parking"></i>
                            </div>

                            <p class="text-base font-semibold text-calm-900"
                               @onclick="HandleParkingTitleClick">@Texts.MapTitle</p>
                        </div>

                        <div class="workspace-parking-header-floor flex items-center justify-center gap-2"
                             style="@FloorControlsStyle">
                            <button class="inline-flex h-12 w-12 items-center justify-center rounded-md bg-white/85 text-calm-700 transition-all duration-500 ease-out hover:bg-calm-100 disabled:cursor-default disabled:opacity-50"
                                    type="button"
                                    disabled="@(!CanMoveToPreviousFloor)"
                                    @onclick="ShowPreviousFloor">
                                <i data-lucide="chevrons-down"></i>
                            </button>

                            <div class="flex h-12 w-12 items-center justify-center rounded-md bg-white/85">
                                <p class="text-base font-semibold text-calm-900">@ActiveFloor</p>
                            </div>

                            <button class="inline-flex h-12 w-12 items-center justify-center rounded-md bg-white/85 text-calm-700 transition-all duration-500 ease-out hover:bg-calm-100 disabled:cursor-default disabled:opacity-50"
                                    type="button"
                                    disabled="@(!CanMoveToNextFloor)"
                                    @onclick="ShowNextFloor">
                                <i data-lucide="chevrons-up"></i>
                            </button>
                        </div>
                    </div>

                    <div class="workspace-parking-floor-layer min-h-[12.5rem] rounded-md bg-white/85 px-4 py-4 text-calm-700 @(IsFullscreen ? "workspace-parking-fullscreen-floor" : "")"
                         style="@FloorLayerStyle">
                        <div class="@(IsFullscreen ? "workspace-parking-fullscreen-aspect" : "")"
                             style="@(IsFullscreen ? "" : "position: relative; width: 100%; aspect-ratio: 600 / 505; min-height: 12.5rem;")">
                            <div style="position: absolute; inset: 1rem;">
                                <img src="@ParkingMapImagePath"
                                     alt=""
                                     style="position: absolute; inset: 0; width: 100%; height: 100%;"/>

                                @foreach (var slot in VisibleSlots)
                                {
                                    <div style="@GetSlotPositionStyle(slot)">
                                        <div class="flex flex-col items-center gap-2">
                                            <button class="@GetMarkerClass(slot)"
                                                    style="@MarkerSizeStyle"
                                                    type="button"
                                                    @onclick="@(() => SelectSlot(slot.Id))">
                                                <span @key="@($"marker-{slot.Id}-{GetMarkerIcon(slot)}")" style="display: contents;">
                                                    <i data-lucide="@GetMarkerIcon(slot)" style="width: 56%; height: 56%;"></i>
                                                </span>
                                            </button>

                                            <span class="font-semibold text-calm-900"
                                                  style="@MarkerLabelStyle">@slot.Label</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </article>

                @if (!IsFullscreen && SelectedSlot is not null)
                {
                    <article class="@DetailsClass" style="@DetailsStyle">
                        <div class="flex flex-col items-stretch gap-4 sm:flex-row">
                            <div class="flex-1 rounded-md bg-white/90 p-5 text-calm-900">
                                <div class="flex h-full flex-col justify-center">
                                    <div class="mb-4 flex items-center justify-center gap-3">
                                        <div class="@SelectedSlotBadgeClass">
                                            <span @key="@($"sel-{SelectedSlotIcon}")" style="display: contents;">
                                                <i data-lucide="@SelectedSlotIcon"></i>
                                            </span>
                                        </div>

                                        <div class="text-center">
                                            <p class="text-base font-semibold text-calm-700">@Texts.SlotTitle</p>
                                            <p class="text-lg font-semibold text-calm-900">@SelectedSlot.Label</p>
                                        </div>
                                    </div>

                                    <div class="rounded-md @SelectedSlotInfoClass px-4 py-4 text-center">
                                        <p class="text-base font-semibold">@SelectedSlotStateLabel</p>
                                    </div>
                                </div>
                            </div>

                            <div class="flex-1 rounded-md bg-white/90 p-5 text-calm-900">
                                <div class="flex h-full flex-col justify-center gap-3">
                                    <div class="rounded-md bg-calm-50 px-4 py-3 text-center text-calm-900">
                                        <p class="mb-2 text-sm font-semibold text-calm-700">@Texts.OccupiedDurationLabel</p>
                                        <p class="text-lg font-semibold text-calm-900">@SelectedSlotDurationLabel</p>
                                    </div>
                                    <div class="rounded-md bg-calm-50 px-4 py-3 text-center text-calm-900">
                                        <p class="mb-2 text-sm font-semibold text-calm-700">@Texts.RfidCardLabel</p>
                                        <p class="text-base font-semibold text-calm-900">@GetSlotRfidLabel(SelectedSlot)</p>
                                    </div>
                                </div>
                            </div>

                            <div class="shrink-0 rounded-md bg-white/90 p-5 text-calm-900">
                                <div class="flex h-full flex-col items-center justify-center gap-3">
                                    <button class="inline-flex h-12 w-12 items-center justify-center rounded-md bg-mint-100 text-calm-900 transition-all duration-500 ease-out hover:bg-mint-200 disabled:cursor-default disabled:opacity-50"
                                            type="button"
                                            aria-label="Show LED route"
                                            disabled="@(!CanShowRouteToSelectedSlot)"
                                            @onclick="ShowRouteToSelectedSlotAsync">
                                        <i data-lucide="route"></i>
                                    </button>

                                    <button class="inline-flex h-12 w-12 items-center justify-center rounded-md bg-warm-100 text-calm-900 transition-all duration-500 ease-out hover:bg-warm-200 disabled:cursor-default disabled:opacity-50"
                                            type="button"
                                            aria-label="Clear LED route"
                                            disabled="@IsBusy"
                                            @onclick="ClearRouteAsync">
                                        <i data-lucide="route-off"></i>
                                    </button>
                                </div>
                            </div>

                            @if (EditParkingEnabled)
                            {
                                <div class="shrink-0 rounded-md bg-white/90 p-5 text-calm-900">
                                    <div class="flex h-full flex-col justify-center gap-4">
                                        <div class="grid gap-3">
                                            <div class="flex gap-3">
                                                <button class='@ParkingEditButtonClass("bg-warm-100 hover:bg-warm-200")'
                                                        type="button"
                                                        disabled="@IsBusy"
                                                        @onclick="ToggleSelectedSlotAsync">
                                                    <i data-lucide="power"></i>
                                                </button>
                                                <button class='@ParkingEditButtonClass("bg-brand-100 hover:bg-brand-200")'
                                                        type="button"
                                                        disabled="@IsBusy"
                                                        @onclick="MoveUpAsync">
                                                    <i data-lucide="arrow-up"></i>
                                                </button>
                                                <button class='@ParkingEditButtonClass("bg-mint-100 hover:bg-mint-200")'
                                                        type="button"
                                                        disabled="@IsBusy"
                                                        @onclick="ResetPositionAsync">
                                                    <i data-lucide="rotate-ccw"></i>
                                                </button>
                                            </div>

                                            <div class="flex gap-3">
                                                <button class='@ParkingEditButtonClass("bg-brand-100 hover:bg-brand-200")'
                                                        type="button"
                                                        disabled="@IsBusy"
                                                        @onclick="MoveLeftAsync">
                                                    <i data-lucide="arrow-left"></i>
                                                </button>
                                                <button class='@ParkingEditButtonClass("bg-brand-100 hover:bg-brand-200")'
                                                        type="button"
                                                        disabled="@IsBusy"
                                                        @onclick="MoveDownAsync">
                                                    <i data-lucide="arrow-down"></i>
                                                </button>
                                                <button class='@ParkingEditButtonClass("bg-brand-100 hover:bg-brand-200")'
                                                        type="button"
                                                        disabled="@IsBusy"
                                                        @onclick="MoveRightAsync">
                                                    <i data-lucide="arrow-right"></i>
                                                </button>
                                            </div>
                                        </div>

                                        <div class="flex gap-3" style="@FloorControlsStyle">
                                            <button class="inline-flex h-12 flex-1 items-center justify-center rounded-md bg-brand-100 text-calm-900 transition-all duration-500 ease-out hover:bg-brand-200 disabled:cursor-default disabled:opacity-50"
                                                    type="button"
                                                    disabled="@(!CanRaiseSelectedSlot)"
                                                    @onclick="RaiseSelectedSlotAsync">
                                                <i data-lucide="chevrons-up"></i>
                                            </button>

                                            <button class="inline-flex h-12 flex-1 items-center justify-center rounded-md bg-brand-100 text-calm-900 transition-all duration-500 ease-out hover:bg-brand-200 disabled:cursor-default disabled:opacity-50"
                                                    type="button"
                                                    disabled="@(!CanLowerSelectedSlot)"
                                                    @onclick="LowerSelectedSlotAsync">
                                                <i data-lucide="chevrons-down"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </article>
                }
            </div>

            @if (IsFullscreen)
            {
                <aside class="workspace-parking-fullscreen-aside space-y-4">
                    <div class="flex gap-3">
                        <div class="flex-1 rounded-md bg-mint-100 p-6 text-center">
                            <p class="text-lg font-semibold text-calm-500">@Texts.FreeCountTitle</p>
                            <p class="mt-2 text-6xl font-extrabold text-calm-900">@FreeSlotCount</p>
                        </div>
                        <div class="flex-1 rounded-md bg-brand-100/70 p-6 text-center">
                            <p class="text-lg font-semibold text-calm-500">@Texts.OccupiedCountTitle</p>
                            <p class="mt-2 text-6xl font-extrabold text-calm-900">@OccupiedSlotCount</p>
                        </div>
                    </div>

                    @if (SelectedSlot is not null)
                    {
                        <div class="workspace-parking-fullscreen-detail rounded-md bg-brand-100/80 p-6">
                            <div class="mb-4 flex items-center justify-center gap-3">
                                <div class="@SelectedSlotBadgeClass">
                                    <span @key="@($"sel-{SelectedSlotIcon}")" style="display: contents;">
                                        <i data-lucide="@SelectedSlotIcon"></i>
                                    </span>
                                </div>
                                <div class="text-center">
                                    <p class="text-base font-semibold text-calm-700">@Texts.SlotTitle</p>
                                    <p class="text-lg font-semibold text-calm-900">@SelectedSlot.Label</p>
                                </div>
                            </div>

                            <div class="workspace-parking-fullscreen-detail-grid flex flex-col gap-3">
                                <div class="rounded-md @SelectedSlotInfoClass px-4 py-3 text-center">
                                    <p class="text-base font-semibold">@SelectedSlotStateLabel</p>
                                </div>
                                <div class="rounded-md bg-white/90 px-4 py-3 text-center text-calm-900">
                                    <p class="mb-2 text-sm font-semibold text-calm-700">@Texts.OccupiedDurationLabel</p>
                                    <p class="text-lg font-semibold text-calm-900">@SelectedSlotDurationLabel</p>
                                </div>
                                <div class="flex gap-3">
                                    <div class="flex-1 rounded-md bg-white/90 px-4 py-3 text-center text-calm-900">
                                        <p class="mb-2 text-sm font-semibold text-calm-700">@Texts.RfidCardLabel</p>
                                        <p class="text-base font-semibold text-calm-900">@GetSlotRfidLabel(SelectedSlot)</p>
                                    </div>
                                    <div class="flex-1 rounded-md bg-white/90 px-4 py-3 text-center text-calm-900">
                                        <p class="mb-2 text-sm font-semibold text-calm-700">@Texts.VehicleNumberLabel</p>
                                        <p class="text-base font-semibold text-calm-900">@GetSlotVehicleNumberLabel(SelectedSlot)</p>
                                    </div>
                                </div>
                                <div class="rounded-md bg-white/90 px-4 py-3 text-center text-calm-900">
                                    <p class="mb-2 text-sm font-semibold text-calm-700">@Texts.VehicleDescriptionLabel</p>
                                    <p class="text-base font-semibold text-calm-900">@GetSlotVehicleDescriptionLabel(SelectedSlot)</p>
                                </div>
                                <div class="workspace-parking-fullscreen-snapshot rounded-md bg-white/90 px-4 py-3 text-center text-calm-900">
                                    <p class="mb-2 text-sm font-semibold text-calm-700">@Texts.EntrySnapshotLabel</p>
                                    @{
                                        var snapshotSource = GetSlotEntrySnapshotSource(SelectedSlot);
                                    }
                                    @if (!string.IsNullOrWhiteSpace(snapshotSource))
                                    {
                                        <img src="@snapshotSource"
                                             alt=""
                                             class="workspace-parking-fullscreen-snapshot-img" />
                                    }
                                    else
                                    {
                                        <p class="text-base font-semibold text-calm-900">@Texts.UndefinedValueLabel</p>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </aside>
            }
        </section>
    </div>
}
